# Optional: Set an ADMIN_KEY to protect the /admin endpoints (Legacy fallback).
# If left empty, admin endpoints still work via role-based auth.
ADMIN_KEY=your_super_secret_admin_key_here

# Google OAuth client ID used by the backend to validate Google ID tokens.
# This must match the client ID used by the frontend GoogleLogin component.
GOOGLE_CLIENT_ID=your_google_oauth_client_id_here

# Comma-separated list of email addresses that automatically get admin role
# on registration/login. Example: admin@example.com,owner@gmail.com
DEFAULT_ADMIN_EMAILS=

# Default token limit for newly registered users (Default: 1000000)
DEFAULT_TOKEN_LIMIT=1000000

# Comma-separated frontend origins allowed to call the backend from browsers.
# Use production domains plus local dev origins as needed.
CORS_ALLOW_ORIGINS=https://aistudio.mineway.cloud,http://localhost:5173,http://127.0.0.1:5173

# Set to 1 only for temporary debugging if you need wildcard CORS.
CORS_ALLOW_ALL=0

# Basic auth endpoint rate limiting (per IP, in-memory).
AUTH_RATE_LIMIT_WINDOW_SEC=60
AUTH_RATE_LIMIT_MAX_REQUESTS=10

# ---- Knowledge Items (KI) — persistent cross-session memory -----------------
# When enabled, the model distills reusable insights from conversations into a
# persistent store (sqlite). At session start, relevant KI summaries are injected
# into the system prompt so the model remembers context across sessions.
#
# Set to 1 to enable automatic distillation (costs extra API calls per session).
KI_DISTILLATION_ENABLED=0
#
# How many conversation turns before triggering a distillation pass.
# Lower = more frequent distillation (more API calls). Higher = less frequent.
KI_DISTILL_EVERY_N_TURNS=6
#
# Maximum number of Knowledge Items to keep in the store.
# Oldest/least-relevant items are pruned when this limit is reached.
KI_MAX_ITEMS=100
#
# Whether to inject KI summaries into the system prompt at the start of each
# session. Set to 0 to disable injection (KIs still stored but not auto-injected).
KI_INJECT_ON_FIRST_TURN=1